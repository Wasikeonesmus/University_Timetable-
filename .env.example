# Copy this file to .env and fill in your values
SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (leave as-is for SQLite, or use postgres://user:pass@host/dbname)
DATABASE_URL=sqlite:///db.sqlite3

# Email (use 'console' for dev, 'smtp' for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Timetable System <no-reply@timetable.edu>

# Firebase Configuration (Optional - Falls back to standard AJAX polling if not provided)
# Backend Admin credentials
FIREBASE_CREDENTIALS_JSON=
FIREBASE_DATABASE_URL=

# Frontend Web App config (safely exposed to client templates)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

